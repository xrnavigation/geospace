{
  "name": "@xrnavigation/geospace",
  "version": "0.0.1",
  "description": "Geometry Utilities",
  "type": "module",
  "main": "./dist/geometry.cjs",
  "module": "./dist/geometry.es.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/geometry.es.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/geometry.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "benchmark": "npm run build --silent && tsc -p tsconfig.benchmarks.json && vitest bench --run",
    "build": "vite build && tsc",
    "preview": "vite preview"
  },
  "keywords": [
    "geometry"
  ],
  "author": "Christopher Toth",
  "license": "UNLICENSED",
  "dependencies": {
    "@types/geojson": "^7946.0.16"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  }
}
